# ===========================================
# Team Memo 環境変数設定
# ===========================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local
#
# 注意:
# - .env.local は .gitignore に含まれるため、コミットされません
# - APIキーは長い文字列のため、コピペ時に文字が欠けたり
#   似た文字（1とl、0とO など）を間違えないよう注意してください
# ===========================================

# Supabase（必須）
# Supabaseダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI（社内チャットボット用・必須）
# Google AI Studio (https://aistudio.google.com/apikey) から取得
# キーは「AIza」で始まる文字列です
GEMINI_API_KEY=

# LLM（メモ要約機能用・任意）
# 使用するプロバイダに応じてキーを設定
# LLM_PROVIDER: "openai" または "anthropic"（未設定の場合は openai）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=

# App
APP_ENV=local
